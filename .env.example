# ============================================
# FixNear — Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values:
#   copy .env.example .env
#
# NEVER commit the actual .env file to GitHub!
# For Render: set these in Dashboard → Environment tab
# ============================================

# Flask secret key (REQUIRED for production)
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# PostgreSQL Database URL (for Render/Neon.tech production)
# Leave blank or remove this line for local MySQL development
DATABASE_URL=

# OTP Email Configuration (Gmail App Password)
MAIL_USERNAME=
MAIL_PASSWORD=

# Admin credentials (used by setup_db_pg.py)
# These are set via environment variables, NOT hardcoded in code
ADMIN_PASSWORD=
TECH_PASSWORD=
