# ============================================
# FixNear - Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values:
#   copy .env.example .env
#
# NEVER commit the actual .env file to GitHub!
# For production: set these in your server environment.
# ============================================

# Flask secret key (REQUIRED for production)
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# Optional production database URL
# Leave blank for local MySQL development
DATABASE_URL=

# OTP Email Configuration (Gmail App Password)
MAIL_USERNAME=
MAIL_PASSWORD=

# Google Maps Platform (optional, for booking page current-location + address autocomplete)
GOOGLE_MAPS_API_KEY=

# Admin credentials (used by setup_db.py)
# These are set via environment variables, NOT hardcoded in code
ADMIN_PASSWORD=
TECH_PASSWORD=
